# Environment Configuration Template
# Copy to .env and fill in actual values

# ==================================================
# Environment
# ==================================================
ENVIRONMENT=development
DEBUG=True

# ==================================================
# Database Configuration
# ==================================================
DATABASE_URL=sqlite:///./thinkloop_ai.db
# For MySQL in production:
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/thinkloop_ai

# ==================================================
# Server Configuration
# ==================================================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ==================================================
# JWT Configuration
# ==================================================
JWT_SECRET_KEY=your-secret-key-change-in-production-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ==================================================
# Gemini API
# ==================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_TIMEOUT=30

# ==================================================
# OAuth2 Configuration
# ==================================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/callback

# ==================================================
# OpenAI Configuration
# ==================================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_FALLBACK_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT_SECONDS=30

# ==================================================
# AWS Configuration
# ==================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# AWS Secrets Manager
SECRETS_MANAGER_NAME=thinkloop-secrets

# ==================================================
# Email Configuration (AWS SES)
# ==================================================
SES_SENDER_EMAIL=noreply@thinkloop.ai
SES_REGION=us-east-1

# ==================================================
# CORS Configuration
# ==================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://thinkloop.ai
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ==================================================
# Rate Limiting
# ==================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=5
RATE_LIMIT_TUTOR_REQUESTS_PER_MINUTE=50

# ==================================================
# Session Configuration
# ==================================================
SESSION_TIMEOUT_MINUTES=1440  # 24 hours
REFRESH_TOKEN_TIMEOUT_DAYS=30

# ==================================================
# Logging Configuration
# ==================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json
SENTRY_DSN=  # For error tracking (optional)

# ==================================================
# Feature Flags
# ==================================================
FEATURE_OAUTH_ENABLED=true
FEATURE_HINT_SYSTEM=true
FEATURE_MISCONCEPTION_DETECTION=true
FEATURE_ANALYTICS=true
FEATURE_ADMIN_PANEL=true

# ==================================================
# Development & Testing
# ==================================================
# Test database (used by pytest)
TEST_DATABASE_URL=sqlite:///./test.db

# Mock OpenAI responses (for testing without API calls)
MOCK_OPENAI=false

# ==================================================
# CloudWatch Configuration (Production)
# ==================================================
CLOUDWATCH_ENABLED=false
CLOUDWATCH_LOG_GROUP=/thinkloop/api
CLOUDWATCH_NAMESPACE=ThinkloopAI

# ==================================================
# Maintenance
# ==================================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance. Please try again later.

# ==================================================
# Domain & URLs
# ==================================================
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8000
API_V1_PREFIX=/api/v1

# ==================================================
# Redis Configuration (Cache)
# ==================================================
REDIS_URL=redis://localhost:6379/0

# ==================================================
# Security
# ==================================================
# Set to false in development only
SECURE_COOKIES=false
HSTS_ENABLED=false
HSTS_MAX_AGE=31536000

# ==================================================
# Content Security Policy
# ==================================================
CSP_ENABLED=false
CSP_SCRIPT_SRC=self
CSP_STYLE_SRC=self unsafe-inline
CSP_IMG_SRC=self data
